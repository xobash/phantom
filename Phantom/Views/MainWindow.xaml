<Window x:Class="Phantom.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:behaviors="clr-namespace:Phantom.Behaviors"
        mc:Ignorable="d"
        Title="Phantom"
        Height="900"
        Width="1500"
        Background="{DynamicResource AppBgBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="228"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="430"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ Gradient mesh: 4 animated color blobs + noise ═══ -->

        <!-- Blob 1 — Blue-Cyan, drifts top-left → center-right -->
        <Rectangle Grid.ColumnSpan="3" IsHitTestVisible="False">
            <Rectangle.Fill>
                <RadialGradientBrush x:Name="Blob1" Center="0.25,0.3" GradientOrigin="0.25,0.3"
                                     RadiusX="0.55" RadiusY="0.55">
                    <GradientStop x:Name="B1S0" Color="#3850A0FF" Offset="0"/>
                    <GradientStop Color="#1830608C" Offset="0.55"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
            <Rectangle.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <PointAnimation Storyboard.TargetName="Blob1" Storyboard.TargetProperty="Center"
                                            From="0.15,0.2" To="0.65,0.55" Duration="0:0:14"
                                            AutoReverse="True" RepeatBehavior="Forever">
                                <PointAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></PointAnimation.EasingFunction>
                            </PointAnimation>
                            <PointAnimation Storyboard.TargetName="Blob1" Storyboard.TargetProperty="GradientOrigin"
                                            From="0.15,0.2" To="0.65,0.55" Duration="0:0:14"
                                            AutoReverse="True" RepeatBehavior="Forever">
                                <PointAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></PointAnimation.EasingFunction>
                            </PointAnimation>
                            <ColorAnimation Storyboard.TargetName="B1S0" Storyboard.TargetProperty="Color"
                                            From="#3850A0FF" To="#382898E0" Duration="0:0:9"
                                            AutoReverse="True" RepeatBehavior="Forever">
                                <ColorAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></ColorAnimation.EasingFunction>
                            </ColorAnimation>
                            <DoubleAnimation Storyboard.TargetName="Blob1" Storyboard.TargetProperty="RadiusX"
                                             From="0.45" To="0.65" Duration="0:0:11"
                                             AutoReverse="True" RepeatBehavior="Forever">
                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="Blob1" Storyboard.TargetProperty="RadiusY"
                                             From="0.5" To="0.6" Duration="0:0:13"
                                             AutoReverse="True" RepeatBehavior="Forever">
                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Rectangle.Triggers>
        </Rectangle>

        <!-- Blob 2 — Purple-Magenta, drifts bottom-right → top-center -->
        <Rectangle Grid.ColumnSpan="3" IsHitTestVisible="False">
            <Rectangle.Fill>
                <RadialGradientBrush x:Name="Blob2" Center="0.75,0.7" GradientOrigin="0.75,0.7"
                                     RadiusX="0.5" RadiusY="0.5">
                    <GradientStop x:Name="B2S0" Color="#34A050E0" Offset="0"/>
                    <GradientStop Color="#146030A0" Offset="0.5"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
            <Rectangle.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <PointAnimation Storyboard.TargetName="Blob2" Storyboard.TargetProperty="Center"
                                            From="0.8,0.75" To="0.35,0.25" Duration="0:0:16"
                                            AutoReverse="True" RepeatBehavior="Forever">
                                <PointAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></PointAnimation.EasingFunction>
                            </PointAnimation>
                            <PointAnimation Storyboard.TargetName="Blob2" Storyboard.TargetProperty="GradientOrigin"
                                            From="0.8,0.75" To="0.35,0.25" Duration="0:0:16"
                                            AutoReverse="True" RepeatBehavior="Forever">
                                <PointAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></PointAnimation.EasingFunction>
                            </PointAnimation>
                            <ColorAnimation Storyboard.TargetName="B2S0" Storyboard.TargetProperty="Color"
                                            From="#34A050E0" To="#34E060A0" Duration="0:0:12"
                                            AutoReverse="True" RepeatBehavior="Forever">
                                <ColorAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></ColorAnimation.EasingFunction>
                            </ColorAnimation>
                            <DoubleAnimation Storyboard.TargetName="Blob2" Storyboard.TargetProperty="RadiusX"
                                             From="0.4" To="0.6" Duration="0:0:13"
                                             AutoReverse="True" RepeatBehavior="Forever">
                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Rectangle.Triggers>
        </Rectangle>

        <!-- Blob 3 — Teal-Emerald, drifts center-top → bottom-left -->
        <Rectangle Grid.ColumnSpan="3" IsHitTestVisible="False">
            <Rectangle.Fill>
                <RadialGradientBrush x:Name="Blob3" Center="0.5,0.15" GradientOrigin="0.5,0.15"
                                     RadiusX="0.4" RadiusY="0.4">
                    <GradientStop x:Name="B3S0" Color="#2840C8A0" Offset="0"/>
                    <GradientStop Color="#10208868" Offset="0.5"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
            <Rectangle.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <PointAnimation Storyboard.TargetName="Blob3" Storyboard.TargetProperty="Center"
                                            From="0.55,0.1" To="0.2,0.8" Duration="0:0:18"
                                            AutoReverse="True" RepeatBehavior="Forever">
                                <PointAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></PointAnimation.EasingFunction>
                            </PointAnimation>
                            <PointAnimation Storyboard.TargetName="Blob3" Storyboard.TargetProperty="GradientOrigin"
                                            From="0.55,0.1" To="0.2,0.8" Duration="0:0:18"
                                            AutoReverse="True" RepeatBehavior="Forever">
                                <PointAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></PointAnimation.EasingFunction>
                            </PointAnimation>
                            <ColorAnimation Storyboard.TargetName="B3S0" Storyboard.TargetProperty="Color"
                                            From="#2840C8A0" To="#2830D8D0" Duration="0:0:10"
                                            AutoReverse="True" RepeatBehavior="Forever">
                                <ColorAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></ColorAnimation.EasingFunction>
                            </ColorAnimation>
                            <DoubleAnimation Storyboard.TargetName="Blob3" Storyboard.TargetProperty="RadiusY"
                                             From="0.35" To="0.55" Duration="0:0:15"
                                             AutoReverse="True" RepeatBehavior="Forever">
                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Rectangle.Triggers>
        </Rectangle>

        <!-- Blob 4 — Warm pink-amber accent, bottom-center drift -->
        <Rectangle Grid.ColumnSpan="3" IsHitTestVisible="False">
            <Rectangle.Fill>
                <RadialGradientBrush x:Name="Blob4" Center="0.6,0.85" GradientOrigin="0.6,0.85"
                                     RadiusX="0.4" RadiusY="0.35">
                    <GradientStop x:Name="B4S0" Color="#22E06888" Offset="0"/>
                    <GradientStop Color="#0CA04060" Offset="0.5"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
            <Rectangle.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <PointAnimation Storyboard.TargetName="Blob4" Storyboard.TargetProperty="Center"
                                            From="0.65,0.9" To="0.4,0.5" Duration="0:0:20"
                                            AutoReverse="True" RepeatBehavior="Forever">
                                <PointAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></PointAnimation.EasingFunction>
                            </PointAnimation>
                            <PointAnimation Storyboard.TargetName="Blob4" Storyboard.TargetProperty="GradientOrigin"
                                            From="0.65,0.9" To="0.4,0.5" Duration="0:0:20"
                                            AutoReverse="True" RepeatBehavior="Forever">
                                <PointAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></PointAnimation.EasingFunction>
                            </PointAnimation>
                            <ColorAnimation Storyboard.TargetName="B4S0" Storyboard.TargetProperty="Color"
                                            From="#22E06888" To="#22D8A050" Duration="0:0:11"
                                            AutoReverse="True" RepeatBehavior="Forever">
                                <ColorAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></ColorAnimation.EasingFunction>
                            </ColorAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Rectangle.Triggers>
        </Rectangle>

        <!-- Film grain noise overlay -->
        <Rectangle Grid.ColumnSpan="3" IsHitTestVisible="False" Opacity="0.04"
                   behaviors:NoiseOverlayBehavior.IsEnabled="True"/>

        <Border Grid.Column="0" BorderBrush="{DynamicResource DarkBorderBrush}" BorderThickness="0,0,1,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#C01B1B1E" Offset="0"/>
                    <GradientStop Color="#C4181824" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Resources>
                <Style x:Key="NavigationListItemStyle" TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Margin" Value="0,4"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Grid>
                                    <Border x:Name="ItemBorder" CornerRadius="10" Padding="10"
                                            Background="{DynamicResource NavItemBackgroundBrush}"
                                            BorderBrush="{DynamicResource NavItemBorderBrush}"
                                            BorderThickness="1">
                                        <ContentPresenter/>
                                    </Border>
                                    <Rectangle x:Name="AccentBar" Width="3"
                                               HorizontalAlignment="Left"
                                               RadiusX="1.5" RadiusY="1.5"
                                               Margin="1,6,0,6"
                                               Visibility="Collapsed">
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#1FA3E2" Offset="0"/>
                                                <GradientStop Color="#7C5CE0" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource NavItemHoverBrush}"/>
                                        <Setter TargetName="ItemBorder" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#3860B0F0" BlurRadius="16" ShadowDepth="0" Opacity="0.40"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource NavItemSelectedBrush}"/>
                                        <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#5898D0FF"/>
                                        <Setter TargetName="AccentBar" Property="Visibility" Value="Visible"/>
                                        <Setter TargetName="ItemBorder" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#4870B0F0" BlurRadius="22" ShadowDepth="0" Opacity="0.50"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                <DataTemplate x:Key="NavigationItemTemplate">
                    <DockPanel>
                        <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="18" Width="24" VerticalAlignment="Center" Foreground="{DynamicResource MutedTextBrush}"/>
                        <TextBlock Text="{Binding Label}" FontSize="16" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{DynamicResource DarkTextBrush}"/>
                    </DockPanel>
                </DataTemplate>
            </Border.Resources>

            <DockPanel Margin="12,8,12,12" LastChildFill="False">
                <ListBox DockPanel.Dock="Top"
                         ItemsSource="{Binding Navigation}"
                         SelectedItem="{Binding SelectedNavigation}"
                         BorderThickness="0"
                         Background="Transparent"
                         HorizontalContentAlignment="Stretch"
                         ItemContainerStyle="{StaticResource NavigationListItemStyle}"
                         ItemTemplate="{StaticResource NavigationItemTemplate}"/>

                <Button DockPanel.Dock="Bottom"
                        Margin="0,20,0,0"
                        Height="44"
                        Command="{Binding OpenSettingsCommand}"
                        Background="{DynamicResource NavItemBackgroundBrush}"
                        BorderBrush="{DynamicResource NavItemBorderBrush}"
                        BorderThickness="1"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Padding" Value="10"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="SettingsBorder"
                                                CornerRadius="10"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="SettingsBorder" Property="Background" Value="{DynamicResource NavItemHoverBrush}"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsSettingsSelected}" Value="True">
                                                <Setter TargetName="SettingsBorder" Property="Background" Value="{DynamicResource NavItemSelectedBrush}"/>
                                                <Setter TargetName="SettingsBorder" Property="BorderBrush" Value="#5898D0FF"/>
                                                <Setter TargetName="SettingsBorder" Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#4870B0F0" BlurRadius="22" ShadowDepth="0" Opacity="0.50"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <DockPanel>
                        <TextBlock Text="{Binding SettingsNavigationItem.Icon}" FontFamily="Segoe MDL2 Assets" FontSize="18" Width="24" VerticalAlignment="Center" Foreground="{DynamicResource MutedTextBrush}"/>
                        <TextBlock Text="{Binding SettingsNavigationItem.Label}" FontSize="16" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{DynamicResource DarkTextBrush}"/>
                    </DockPanel>
                </Button>
            </DockPanel>
        </Border>

        <!-- Gradient accent edge: sidebar → content -->
        <Rectangle Grid.Column="0" Width="1.5" HorizontalAlignment="Right" IsHitTestVisible="False" Opacity="0.6">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#00000000" Offset="0"/>
                    <GradientStop Color="#4050A8FF" Offset="0.25"/>
                    <GradientStop Color="#508060E0" Offset="0.55"/>
                    <GradientStop Color="#3040C8A0" Offset="0.8"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Border Grid.Column="1" Margin="12" Style="{StaticResource DarkCardStyle}" Background="#B8202028">
            <ContentControl Content="{Binding CurrentSectionViewModel}"/>
        </Border>

        <!-- Gradient accent edge: content → terminal -->
        <Rectangle Grid.Column="2" Width="1.5" HorizontalAlignment="Left" IsHitTestVisible="False" Opacity="0.5">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#00000000" Offset="0"/>
                    <GradientStop Color="#3060A0E8" Offset="0.3"/>
                    <GradientStop Color="#407050E0" Offset="0.6"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Border Grid.Column="2" Margin="0" BorderBrush="{DynamicResource DarkBorderBrush}" BorderThickness="1,0,0,0" Background="{DynamicResource TerminalBackgroundBrush}">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="8,8,8,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button Content="Cancel" Width="86" Margin="4" Command="{Binding CancelCurrentOperationCommand}" Style="{StaticResource DarkButtonStyle}"/>
                            <Button Content="Copy Log" Width="96" Margin="4" Command="{Binding CopyLogCommand}" Style="{StaticResource DarkButtonStyle}"/>
                            <Button Content="Open Logs Folder" Width="146" Margin="4" Command="{Binding OpenLogsFolderCommand}" Style="{StaticResource DarkButtonStyle}"/>
                        </StackPanel>
                        <Border Grid.Column="1"
                                Margin="8,4,4,4"
                                Padding="10,4"
                                CornerRadius="10"
                                BorderBrush="{DynamicResource DarkBorderBrush}"
                                BorderThickness="1"
                                Background="{DynamicResource DarkCard2Brush}">
                            <TextBlock FontSize="13" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                        <Setter Property="Text" Value="Idle"/>
                                        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOperationRunning}" Value="True">
                                                <Setter Property="Text" Value="Running"/>
                                                <Setter Property="Foreground" Value="#87E0A2"/>
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#6087E0A2" BlurRadius="8" ShadowDepth="0" Opacity="0.55"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </Grid>

                    <DockPanel Grid.Row="1" Margin="4,4,4,0" LastChildFill="False">
                        <ComboBox x:Name="ConsoleFilterCombo"
                                  DockPanel.Dock="Left"
                                  Width="160"
                                  Margin="0,0,8,0"
                                  SelectedIndex="0"
                                  SelectionChanged="OnConsoleFilterChanged"
                                  Style="{StaticResource DarkComboBoxStyle}">
                            <ComboBoxItem Content="All logs"/>
                            <ComboBoxItem Content="No Trace"/>
                            <ComboBoxItem Content="Warnings+" />
                            <ComboBoxItem Content="Errors only"/>
                        </ComboBox>
                        <ProgressBar DockPanel.Dock="Right"
                                     Width="150"
                                     Height="6"
                                     Margin="8,12,0,0"
                                     IsIndeterminate="True"
                                     Foreground="{DynamicResource ConsoleAccentBlueBrush}"
                                     Background="{DynamicResource DarkCard2Brush}">
                            <ProgressBar.Style>
                                <Style TargetType="ProgressBar">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsOperationRunning}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ProgressBar.Style>
                        </ProgressBar>
                    </DockPanel>
                </Grid>
                <RichTextBox Name="ConsoleTextBox"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             Background="{DynamicResource TerminalBackgroundBrush}"
                             Foreground="{DynamicResource TerminalForegroundBrush}"
                             BorderThickness="0"
                             FontFamily="Consolas"
                             FontSize="14"
                             Margin="8"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
