<Window x:Class="Phantom.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Phantom"
        Height="900"
        Width="1500"
        Background="{DynamicResource AppBgBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="228"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="430"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ Ambient light layer: drifting radial glows ═══ -->
        <Rectangle Grid.ColumnSpan="3" IsHitTestVisible="False">
            <Rectangle.Fill>
                <RadialGradientBrush x:Name="AmbientBrush1"
                                     Center="0.3,0.3" GradientOrigin="0.3,0.3"
                                     RadiusX="0.85" RadiusY="0.85">
                    <GradientStop x:Name="Amb1Stop0" Color="#1E508CFF" Offset="0"/>
                    <GradientStop Color="#0C6040C8" Offset="0.5"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
            <Rectangle.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <PointAnimation Storyboard.TargetName="AmbientBrush1"
                                            Storyboard.TargetProperty="Center"
                                            From="0.2,0.2" To="0.7,0.65"
                                            Duration="0:0:12" AutoReverse="True"
                                            RepeatBehavior="Forever">
                                <PointAnimation.EasingFunction>
                                    <SineEase EasingMode="EaseInOut"/>
                                </PointAnimation.EasingFunction>
                            </PointAnimation>
                            <PointAnimation Storyboard.TargetName="AmbientBrush1"
                                            Storyboard.TargetProperty="GradientOrigin"
                                            From="0.2,0.2" To="0.7,0.65"
                                            Duration="0:0:12" AutoReverse="True"
                                            RepeatBehavior="Forever">
                                <PointAnimation.EasingFunction>
                                    <SineEase EasingMode="EaseInOut"/>
                                </PointAnimation.EasingFunction>
                            </PointAnimation>
                            <ColorAnimation Storyboard.TargetName="Amb1Stop0"
                                            Storyboard.TargetProperty="Color"
                                            From="#1E508CFF" To="#1E2090D8"
                                            Duration="0:0:8" AutoReverse="True"
                                            RepeatBehavior="Forever">
                                <ColorAnimation.EasingFunction>
                                    <SineEase EasingMode="EaseInOut"/>
                                </ColorAnimation.EasingFunction>
                            </ColorAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Rectangle.Triggers>
        </Rectangle>

        <Rectangle Grid.ColumnSpan="3" IsHitTestVisible="False">
            <Rectangle.Fill>
                <RadialGradientBrush x:Name="AmbientBrush2"
                                     Center="0.7,0.7" GradientOrigin="0.7,0.7"
                                     RadiusX="0.7" RadiusY="0.7">
                    <GradientStop x:Name="Amb2Stop0" Color="#16A050E0" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
            <Rectangle.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <PointAnimation Storyboard.TargetName="AmbientBrush2"
                                            Storyboard.TargetProperty="Center"
                                            From="0.75,0.7" To="0.3,0.35"
                                            Duration="0:0:15" AutoReverse="True"
                                            RepeatBehavior="Forever">
                                <PointAnimation.EasingFunction>
                                    <SineEase EasingMode="EaseInOut"/>
                                </PointAnimation.EasingFunction>
                            </PointAnimation>
                            <PointAnimation Storyboard.TargetName="AmbientBrush2"
                                            Storyboard.TargetProperty="GradientOrigin"
                                            From="0.75,0.7" To="0.3,0.35"
                                            Duration="0:0:15" AutoReverse="True"
                                            RepeatBehavior="Forever">
                                <PointAnimation.EasingFunction>
                                    <SineEase EasingMode="EaseInOut"/>
                                </PointAnimation.EasingFunction>
                            </PointAnimation>
                            <ColorAnimation Storyboard.TargetName="Amb2Stop0"
                                            Storyboard.TargetProperty="Color"
                                            From="#16A050E0" To="#16E06080"
                                            Duration="0:0:10" AutoReverse="True"
                                            RepeatBehavior="Forever">
                                <ColorAnimation.EasingFunction>
                                    <SineEase EasingMode="EaseInOut"/>
                                </ColorAnimation.EasingFunction>
                            </ColorAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Rectangle.Triggers>
        </Rectangle>

        <Border Grid.Column="0" BorderBrush="{DynamicResource DarkBorderBrush}" BorderThickness="0,0,1,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#D81B1B1B" Offset="0"/>
                    <GradientStop Color="#DC181820" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Resources>
                <Style x:Key="NavigationListItemStyle" TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Margin" Value="0,4"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Grid>
                                    <Border x:Name="ItemBorder" CornerRadius="10" Padding="10"
                                            Background="{DynamicResource NavItemBackgroundBrush}"
                                            BorderBrush="{DynamicResource NavItemBorderBrush}"
                                            BorderThickness="1">
                                        <ContentPresenter/>
                                    </Border>
                                    <Rectangle x:Name="AccentBar" Width="3"
                                               HorizontalAlignment="Left"
                                               RadiusX="1.5" RadiusY="1.5"
                                               Margin="1,6,0,6"
                                               Visibility="Collapsed">
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#1FA3E2" Offset="0"/>
                                                <GradientStop Color="#7C5CE0" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource NavItemHoverBrush}"/>
                                        <Setter TargetName="ItemBorder" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#2050A0E0" BlurRadius="12" ShadowDepth="0" Opacity="0.28"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource NavItemSelectedBrush}"/>
                                        <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#4088CCFF"/>
                                        <Setter TargetName="AccentBar" Property="Visibility" Value="Visible"/>
                                        <Setter TargetName="ItemBorder" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#3060A0E8" BlurRadius="16" ShadowDepth="0" Opacity="0.35"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                <DataTemplate x:Key="NavigationItemTemplate">
                    <DockPanel>
                        <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="18" Width="24" VerticalAlignment="Center" Foreground="{DynamicResource MutedTextBrush}"/>
                        <TextBlock Text="{Binding Label}" FontSize="16" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{DynamicResource DarkTextBrush}"/>
                    </DockPanel>
                </DataTemplate>
            </Border.Resources>

            <DockPanel Margin="12,8,12,12" LastChildFill="False">
                <ListBox DockPanel.Dock="Top"
                         ItemsSource="{Binding Navigation}"
                         SelectedItem="{Binding SelectedNavigation}"
                         BorderThickness="0"
                         Background="Transparent"
                         HorizontalContentAlignment="Stretch"
                         ItemContainerStyle="{StaticResource NavigationListItemStyle}"
                         ItemTemplate="{StaticResource NavigationItemTemplate}"/>

                <Button DockPanel.Dock="Bottom"
                        Margin="0,20,0,0"
                        Height="44"
                        Command="{Binding OpenSettingsCommand}"
                        Background="{DynamicResource NavItemBackgroundBrush}"
                        BorderBrush="{DynamicResource NavItemBorderBrush}"
                        BorderThickness="1"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Padding" Value="10"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="SettingsBorder"
                                                CornerRadius="10"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="SettingsBorder" Property="Background" Value="{DynamicResource NavItemHoverBrush}"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsSettingsSelected}" Value="True">
                                                <Setter TargetName="SettingsBorder" Property="Background" Value="{DynamicResource NavItemSelectedBrush}"/>
                                                <Setter TargetName="SettingsBorder" Property="BorderBrush" Value="#4088CCFF"/>
                                                <Setter TargetName="SettingsBorder" Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#3060A0E8" BlurRadius="16" ShadowDepth="0" Opacity="0.35"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <DockPanel>
                        <TextBlock Text="{Binding SettingsNavigationItem.Icon}" FontFamily="Segoe MDL2 Assets" FontSize="18" Width="24" VerticalAlignment="Center" Foreground="{DynamicResource MutedTextBrush}"/>
                        <TextBlock Text="{Binding SettingsNavigationItem.Label}" FontSize="16" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{DynamicResource DarkTextBrush}"/>
                    </DockPanel>
                </Button>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Margin="12" Style="{StaticResource DarkCardStyle}" Background="#D5202025">
            <ContentControl Content="{Binding CurrentSectionViewModel}"/>
        </Border>

        <Border Grid.Column="2" Margin="0" BorderBrush="{DynamicResource DarkBorderBrush}" BorderThickness="1,0,0,0" Background="{DynamicResource TerminalBackgroundBrush}">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="8,8,8,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button Content="Cancel" Width="86" Margin="4" Command="{Binding CancelCurrentOperationCommand}" Style="{StaticResource DarkButtonStyle}"/>
                            <Button Content="Copy Log" Width="96" Margin="4" Command="{Binding CopyLogCommand}" Style="{StaticResource DarkButtonStyle}"/>
                            <Button Content="Open Logs Folder" Width="146" Margin="4" Command="{Binding OpenLogsFolderCommand}" Style="{StaticResource DarkButtonStyle}"/>
                        </StackPanel>
                        <Border Grid.Column="1"
                                Margin="8,4,4,4"
                                Padding="10,4"
                                CornerRadius="10"
                                BorderBrush="{DynamicResource DarkBorderBrush}"
                                BorderThickness="1"
                                Background="{DynamicResource DarkCard2Brush}">
                            <TextBlock FontSize="13" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                        <Setter Property="Text" Value="Idle"/>
                                        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOperationRunning}" Value="True">
                                                <Setter Property="Text" Value="Running"/>
                                                <Setter Property="Foreground" Value="#87E0A2"/>
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#6087E0A2" BlurRadius="8" ShadowDepth="0" Opacity="0.55"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </Grid>

                    <DockPanel Grid.Row="1" Margin="4,4,4,0" LastChildFill="False">
                        <ComboBox x:Name="ConsoleFilterCombo"
                                  DockPanel.Dock="Left"
                                  Width="160"
                                  Margin="0,0,8,0"
                                  SelectedIndex="0"
                                  SelectionChanged="OnConsoleFilterChanged"
                                  Style="{StaticResource DarkComboBoxStyle}">
                            <ComboBoxItem Content="All logs"/>
                            <ComboBoxItem Content="No Trace"/>
                            <ComboBoxItem Content="Warnings+" />
                            <ComboBoxItem Content="Errors only"/>
                        </ComboBox>
                        <ProgressBar DockPanel.Dock="Right"
                                     Width="150"
                                     Height="6"
                                     Margin="8,12,0,0"
                                     IsIndeterminate="True"
                                     Foreground="{DynamicResource ConsoleAccentBlueBrush}"
                                     Background="{DynamicResource DarkCard2Brush}">
                            <ProgressBar.Style>
                                <Style TargetType="ProgressBar">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsOperationRunning}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ProgressBar.Style>
                        </ProgressBar>
                    </DockPanel>
                </Grid>
                <RichTextBox Name="ConsoleTextBox"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             Background="{DynamicResource TerminalBackgroundBrush}"
                             Foreground="{DynamicResource TerminalForegroundBrush}"
                             BorderThickness="0"
                             FontFamily="Consolas"
                             FontSize="14"
                             Margin="8"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
