<UserControl x:Class="Phantom.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource AppBgBrush}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="AboutAccordionToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="{DynamicResource DarkCard2Brush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DarkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="HeaderBorder"
                                CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="{DynamicResource RowHoverBackgroundBrush}"/>
                                <Setter TargetName="HeaderBorder" Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="HeaderBorder" Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="HeaderBorder" Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Background="{DynamicResource AppBgBrush}">
        <StackPanel Background="{DynamicResource AppBgBrush}">
            <Border Style="{StaticResource DarkCardStyle}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Theme" FontWeight="SemiBold" Foreground="{DynamicResource DarkTextBrush}"/>
                            <TextBlock Text="Auto follows Windows. Light and Dark override it." Margin="0,6,0,0" Foreground="{DynamicResource MutedTextBrush}"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1"
                                  Width="140"
                                  Margin="12,0,0,0"
                                  VerticalAlignment="Center"
                                  ItemsSource="{Binding ThemeModes}"
                                  SelectedItem="{Binding SelectedThemeMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource DarkComboBoxStyle}"/>
                    </Grid>
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Accent color" FontWeight="SemiBold" Foreground="{DynamicResource DarkTextBrush}"/>
                            <TextBlock Text="Windows follows the current system accent color." Margin="0,6,0,0" Foreground="{DynamicResource MutedTextBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Margin="12,0,0,0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Border Width="34"
                                    Height="34"
                                    Margin="0,0,8,0"
                                    CornerRadius="17"
                                    Background="{Binding AccentPreviewBrush}"
                                    BorderBrush="{DynamicResource AccentBorderBrush}"
                                    BorderThickness="1"
                                    ToolTip="{Binding CurrentAccentColor}"/>
                            <ComboBox Width="130"
                                      Margin="0,0,8,0"
                                      ItemsSource="{Binding AccentModes}"
                                      SelectedItem="{Binding SelectedAccentMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Style="{StaticResource DarkComboBoxStyle}"/>
                            <TextBox Width="112"
                                     Text="{Binding CustomAccentColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsCustomAccentSelected}"
                                     ToolTip="Hex color, for example #0078D4"
                                     Style="{StaticResource DarkTextBoxStyle}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DarkCardStyle}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Enable destructive operations" FontWeight="SemiBold" Foreground="{DynamicResource DarkTextBrush}"/>
                            <TextBlock Text="When OFF, destructive removals stay hidden/disabled." Margin="0,6,0,0" Foreground="{DynamicResource MutedTextBrush}"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" IsChecked="{Binding EnableDestructiveOperations}" Style="{StaticResource SwitchToggleStyle}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DarkCardStyle}">
                <StackPanel>
                    <CheckBox Content="Create restore point before dangerous operations" IsChecked="{Binding CreateRestorePointBeforeDangerousOperations}" Style="{StaticResource DarkCheckBoxStyle}"/>
                    <TextBlock Text="Optional safety net before risky changes (Windows may limit restore point frequency)." Margin="0,6,0,0" Foreground="{DynamicResource MutedTextBrush}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DarkCardStyle}">
                <StackPanel>
                    <TextBlock Text="Script safety guards are always enabled." FontWeight="SemiBold" Foreground="{DynamicResource DarkTextBrush}"/>
                    <TextBlock Text="Dynamic execution patterns, encoded command aliases, and untrusted download hosts are blocked by default." Margin="0,6,0,0" Foreground="{DynamicResource MutedTextBrush}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DarkCardStyle}">
                <StackPanel>
                    <TextBlock Text="Home refresh interval (seconds)" Foreground="{DynamicResource DarkTextBrush}"/>
                    <TextBox Margin="0,8,0,0" Width="120" Text="{Binding HomeRefreshSeconds}" Style="{StaticResource DarkTextBoxStyle}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DarkCardStyle}">
                <StackPanel>
                    <TextBlock Text="Log retention" FontWeight="SemiBold" Foreground="{DynamicResource DarkTextBrush}"/>
                    <TextBlock Text="Max log files" Margin="0,10,0,0" Foreground="{DynamicResource MutedTextBrush}"/>
                    <TextBox Width="120" Text="{Binding MaxLogFiles}" Style="{StaticResource DarkTextBoxStyle}"/>
                    <TextBlock Text="Max total size (bytes)" Margin="0,10,0,0" Foreground="{DynamicResource MutedTextBrush}"/>
                    <TextBox Width="180" Text="{Binding MaxTotalLogSizeBytes}" Style="{StaticResource DarkTextBoxStyle}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DarkCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Text="Local logs"
                                   FontWeight="SemiBold"
                                   FontSize="18"
                                   Foreground="{DynamicResource DarkTextBrush}"/>
                        <TextBlock Text="Moved from Logs/About. View recent log files and preview contents."
                                   Margin="0,6,0,0"
                                   Foreground="{DynamicResource MutedTextBrush}"/>
                    </StackPanel>

                    <WrapPanel Grid.Row="0"
                               Grid.Column="1"
                               Margin="12,0,0,0"
                               VerticalAlignment="Top">
                        <Button Command="{Binding RefreshLogsCommand}"
                                Style="{StaticResource RefreshIconButtonStyle}"
                                ToolTip="Refresh log file list"/>
                        <Button Content="Open logs folder"
                                Command="{Binding OpenLogCommand}"
                                Style="{StaticResource DarkButtonStyle}"/>
                    </WrapPanel>

                    <Grid Grid.Row="1"
                          Grid.ColumnSpan="2"
                          Margin="0,12,0,0"
                          Height="320">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="{DynamicResource InputBackgroundBrush}"
                                BorderBrush="{DynamicResource DarkBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Log files"
                                           Margin="10,8,10,6"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource DarkTextBrush}"/>
                                <ListBox Grid.Row="1"
                                         Margin="8,0,8,8"
                                         ItemsSource="{Binding LogFiles}"
                                         SelectedItem="{Binding SelectedLog, Mode=TwoWay}"
                                         Background="{DynamicResource InputBackgroundBrush}"
                                         Foreground="{DynamicResource DarkTextBrush}"
                                         BorderBrush="{DynamicResource DarkBorderBrush}"
                                         BorderThickness="1"/>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2"
                                Background="{DynamicResource InputBackgroundBrush}"
                                BorderBrush="{DynamicResource DarkBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Preview"
                                           Margin="10,8,10,6"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource DarkTextBrush}"/>
                                <TextBox Grid.Row="1"
                                         Margin="8,0,8,8"
                                         Text="{Binding SelectedLogContent}"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         FontFamily="Consolas"
                                         Style="{StaticResource DarkTextBoxStyle}"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <TextBlock Text="About"
                       Margin="12,10,12,0"
                       FontWeight="SemiBold"
                       FontSize="18"
                       Foreground="{DynamicResource DarkTextBrush}"/>

            <Border Style="{StaticResource DarkCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ToggleButton Grid.Row="0"
                                  Style="{StaticResource AboutAccordionToggleStyle}"
                                  IsChecked="{Binding IsAboutExpanded, Mode=TwoWay}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Width="34"
                                    Height="34"
                                    CornerRadius="17"
                                    Background="{DynamicResource InputBackgroundBrush}"
                                    BorderBrush="{DynamicResource DarkBorderBrush}"
                                    BorderThickness="1"
                                    VerticalAlignment="Center">
                                <TextBlock Text="&#xE946;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="15"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource DarkTextBrush}"/>
                            </Border>

                            <StackPanel Grid.Column="1" Margin="12,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding AppDisplayWithVersion}"
                                           FontWeight="SemiBold"
                                           FontSize="17"
                                           Foreground="{DynamicResource DarkTextBrush}"/>
                                <TextBlock Text="{Binding AboutSummary}"
                                           Margin="0,3,0,0"
                                           FontSize="14"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <TextBlock Grid.Column="2"
                                       Text="{Binding AboutChevronGlyph}"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="15"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource MutedTextBrush}"/>
                        </Grid>
                    </ToggleButton>

                    <Border Grid.Row="1"
                            Margin="0,10,0,0"
                            Padding="2,2,2,0"
                            Visibility="{Binding IsAboutExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <StackPanel Margin="4,0,4,10"
                                        Visibility="{Binding IsReadmeLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ProgressBar Height="3" IsIndeterminate="True"/>
                                <TextBlock Text="Loading README..."
                                           Margin="0,8,0,0"
                                           FontSize="13"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                            </StackPanel>

                            <Border Margin="0,0,0,10"
                                    Padding="10"
                                    Background="{DynamicResource InputBackgroundBrush}"
                                    BorderBrush="{DynamicResource DarkBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Visibility="{Binding HasReadmeError, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="{Binding ReadmeErrorText}"
                                           FontSize="14"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                            </Border>

                            <Border Background="{DynamicResource InputBackgroundBrush}"
                                    BorderBrush="{DynamicResource DarkBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Visibility="{Binding HasReadmeContent, Converter={StaticResource BoolToVisibilityConverter}}">
                                <FlowDocumentScrollViewer Document="{Binding ReadmeDocument}"
                                                          MaxHeight="420"
                                                          Padding="12,10,12,6"
                                                          IsToolBarVisible="False"
                                                          Foreground="{DynamicResource DarkTextBrush}"
                                                          Background="{DynamicResource InputBackgroundBrush}"
                                                          VerticalScrollBarVisibility="Auto"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Button Content="Save settings"
                    Width="170"
                    Margin="8,10,8,14"
                    Command="{Binding SaveCommand}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Style="{StaticResource DarkButtonStyle}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
