<UserControl x:Class="Phantom.Views.StoreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource AppBgBrush}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style x:Key="StoreGridTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{DynamicResource DarkTextBrush}"/>
        </Style>
        <Style x:Key="StoreInfoChipStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource DarkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Background" Value="{DynamicResource DarkCard2Brush}"/>
        </Style>
        <Style x:Key="StoreChevronToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource DarkTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource DarkCard2Brush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DarkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ChevronBorder"
                                CornerRadius="7"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <TextBlock Text="{Binding ManagerInstallerChevron}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="{TemplateBinding FontSize}"
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChevronBorder" Property="Background" Value="{DynamicResource RowHoverBackgroundBrush}"/>
                                <Setter TargetName="ChevronBorder" Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid Background="{DynamicResource AppBgBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource DarkCardStyle}" Margin="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="Package Managers"
                               FontSize="21"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource DarkTextBrush}"/>
                    <TextBlock Text="{Binding ManagerSummary}"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="{DynamicResource MutedTextBrush}"/>

                    <Border Margin="0,12,0,8"
                            Padding="10"
                            CornerRadius="8"
                            Background="{DynamicResource DarkCard2Brush}"
                            BorderBrush="{DynamicResource DarkBorderBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="Install package managers"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource DarkTextBrush}"/>
                                <TextBlock Text="Select missing managers used by Store sources."
                                           Margin="0,2,0,0"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Command="{Binding RefreshManagersCommand}"
                                        Style="{StaticResource RefreshIconButtonStyle}"
                                        ToolTip="Refresh package manager status"/>
                                <ToggleButton IsChecked="{Binding ManagerInstallerExpanded, Mode=TwoWay}"
                                              Style="{StaticResource StoreChevronToggleStyle}"
                                              ToolTip="Show package manager installer"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1"
                                        Grid.ColumnSpan="2"
                                        Margin="0,10,0,0"
                                        Visibility="{Binding ManagerInstallerExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ItemsControl ItemsSource="{Binding PackageManagers}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="26"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding Selected, Mode=TwoWay}"
                                                          IsEnabled="{Binding CanInstall}"
                                                          VerticalAlignment="Center"
                                                          Style="{StaticResource DarkCheckBoxStyle}"
                                                          ToolTip="{Binding Description}"/>
                                                <StackPanel Grid.Column="1" Margin="2,0,8,0">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"
                                                               Foreground="{DynamicResource DarkTextBrush}"/>
                                                    <TextBlock Text="{Binding Description}"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"
                                                               Foreground="{DynamicResource MutedTextBrush}"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Status}"
                                                           VerticalAlignment="Center"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource MutedTextBrush}"
                                                           ToolTip="{Binding Source}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Content="Install selected managers"
                                        Command="{Binding InstallSelectedManagersCommand}"
                                        Margin="0,8,0,0"
                                        Style="{StaticResource DarkButtonStyle}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource DarkCardStyle}" Margin="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,10">
                    <WrapPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                        <Button Content="Install selected" Command="{Binding InstallSelectedCommand}" Style="{StaticResource DarkButtonStyle}"/>
                        <Button Content="Uninstall selected" Command="{Binding UninstallSelectedCommand}" Style="{StaticResource DarkButtonStyle}"/>
                        <Button Content="Upgrade selected" Command="{Binding UpgradeSelectedCommand}" Style="{StaticResource DarkButtonStyle}"/>
                        <Button Content="Discover selected" Command="{Binding DiscoverSelectedCommand}" Style="{StaticResource DarkButtonStyle}"/>
                    </WrapPanel>
                    <TextBox DockPanel.Dock="Right"
                             Width="280"
                             Height="38"
                             Margin="8,0,0,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DarkTextBoxStyle}"/>
                    <Button DockPanel.Dock="Right"
                            Command="{Binding RefreshPackageStatusCommand}"
                            Style="{StaticResource RefreshIconButtonStyle}"
                            ToolTip="Refresh package state"/>
                </DockPanel>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding CatalogView}"
                          AutoGenerateColumns="False"
                          IsReadOnly="False"
                          Style="{StaticResource DarkDataGridStyle}"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          ScrollViewer.CanContentScroll="True"
                          EnableRowVirtualization="True"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <DataGrid.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="{x:Type GroupItem}">
                                <Setter Property="Margin" Value="0,0,0,16"/>
                            </Style>
                        </GroupStyle.ContainerStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <Border Margin="0,14,0,8"
                                        Padding="10,6"
                                        CornerRadius="8"
                                        Background="{DynamicResource DarkCard2Brush}"
                                        BorderBrush="{DynamicResource DarkBorderBrush}"
                                        BorderThickness="1">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}"/>
                                </Border>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </DataGrid.GroupStyle>
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="Sel"
                                            Binding="{Binding Selected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Width="48"/>
                    <DataGridTemplateColumn Header="App" Width="*" MinWidth="260">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="34"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding DisplayName}"
                                               Style="{StaticResource StoreGridTextStyle}"
                                               Margin="0,0,8,0"/>

                                    <Border Grid.Column="1"
                                            Style="{StaticResource StoreInfoChipStyle}"
                                            Cursor="Help"
                                            HorizontalAlignment="Right"
                                            ToolTipService.ShowDuration="60000"
                                            ToolTipService.InitialShowDelay="120">
                                        <Border.ToolTip>
                                            <ToolTip Background="{DynamicResource DarkCard2Brush}"
                                                     Foreground="{DynamicResource DarkTextBrush}"
                                                     BorderBrush="{DynamicResource DarkBorderBrush}"
                                                     BorderThickness="1"
                                                     MaxWidth="520"
                                                     Placement="Mouse">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource DarkTextBrush}"/>
                                                    <TextBlock FontSize="13"
                                                               Margin="0,4,0,0"
                                                               TextWrapping="Wrap"
                                                               Foreground="{DynamicResource DarkTextBrush}">
                                                        <Run Text="Purpose: "/>
                                                        <Run Text="{Binding PurposeSummary}"/>
                                                    </TextBlock>
                                                    <TextBlock FontSize="12"
                                                               Margin="0,8,0,0"
                                                               TextWrapping="Wrap"
                                                               Foreground="{DynamicResource MutedTextBrush}">
                                                        <Run Text="Source: "/>
                                                        <Run Text="{Binding SourceSummary}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </ToolTip>
                                        </Border.ToolTip>
                                        <TextBlock Text="i"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="14"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
